<launch>
  <!-- Load robot description from xacro -->
  <param name="robot_description" command="$(find xacro)/xacro '$(find arctos_urdf_description)/urdf/arctos_urdf.xacro'" />

  <!-- Start MoveIt move_group node -->
  <node name="move_group" pkg="moveit_ros_move_group" type="move_group" output="screen" />

  <!-- Start RViz with Motion Planning plugin -->
  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find arctos_moveit)/rviz/moveit.rviz" />

  <!-- Optional: joint state publisher -->
  <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher" />
</launch>
